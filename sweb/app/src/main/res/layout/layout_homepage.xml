<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nexus_bg">

    <!-- Top Navigation -->
    <LinearLayout
        android:id="@+id/top_nav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_workspaces"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Workspaces"
            android:textColor="@color/nexus_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="History"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/btn_privacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Privacy"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Center Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nexus Core"
            android:textColor="@color/nexus_text_primary"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:letterSpacing="0.2"
            android:text="READY FOR QUERIES"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="12sp" />

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="48dp"
            app:cardBackgroundColor="@color/nexus_search_bg"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/nexus_card_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HTTP"
                    android:textColor="@color/nexus_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginRight="16dp"
                    android:background="@color/nexus_card_border" />

                <EditText
                    android:id="@+id/homepage_search_et"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Enter URL or search parameters..."
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:singleLine="true"
                    android:textColor="@color/nexus_text_primary"
                    android:textColorHint="@color/nexus_text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/homepage_search_go"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/nexus_accent"
                    app:cornerRadius="8dp"
                    app:icon="@android:drawable/ic_menu_send"
                    app:iconSize="20dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grid of Shortcuts -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <!-- Github -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tile_github"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/nexus_tile"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/nexus_card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_slideshow"
                        app:tint="@color/nexus_accent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Github"
                        android:textColor="@color/nexus_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Figma -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tile_figma"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/nexus_tile"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/nexus_card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        app:tint="@color/nexus_accent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Figma"
                        android:textColor="@color/nexus_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Analytics -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tile_analytics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/nexus_tile"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/nexus_card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/nexus_accent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Analytics"
                        android:textColor="@color/nexus_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Documentation -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tile_docs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                app:cardBackgroundColor="@color/nexus_tile"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/nexus_card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_info_details"
                        app:tint="@color/nexus_accent" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Documentation"
                        android:textColor="@color/nexus_text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>
    </LinearLayout>

    <!-- Right Side Metrics -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:layout_marginRight="24dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:rotation="-90"
            android:text="RAM USAGE"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="10sp" />

        <ProgressBar
            android:id="@+id/progress_ram"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="4dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:progress="65"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="@color/nexus_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:rotation="-90"
            android:text="LATENCY"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="10sp" />

        <ProgressBar
            android:id="@+id/progress_latency"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="4dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:progress="20"
            android:progressDrawable="@android:drawable/progress_horizontal"
            android:progressTint="@color/nexus_accent" />
    </LinearLayout>

    <!-- Bottom Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Main_Frame_A1"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session: 4h 22m"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_nexus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_margin="24dp"
        android:layout_marginBottom="64dp"
        android:src="@android:drawable/ic_menu_compass"
        app:backgroundTint="@color/nexus_tile"
        app:tint="@color/nexus_accent" />

</RelativeLayout>
