<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nexus_bg">

    <landau.sweb.PinchWebViewContainer
        android:id="@+id/pinch_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/main_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Home View (Nexus Dashboard) -->
            <include
                android:id="@+id/home_view"
                layout="@layout/layout_homepage"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Top Address Bar (Visible only when browsing) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/address_bar_container"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_alignParentTop="true"
                android:visibility="gone"
                app:cardBackgroundColor="@color/nexus_sidebar"
                app:cardElevation="4dp"
                app:cardCornerRadius="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp">

                    <ImageView
                        android:id="@+id/btn_drawer"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@drawable/menu"
                        app:tint="@color/nexus_text_secondary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/address_bar_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp">

                        <ImageView
                            android:id="@+id/iv_lock"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_secure"
                            app:tint="@color/nexus_accent" />

                        <AutoCompleteTextView
                            android:id="@+id/et"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:completionThreshold="1"
                            android:imeActionLabel="Go"
                            android:imeOptions="actionGo"
                            android:inputType="textUri"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp"
                            android:textColor="@color/nexus_text_primary"
                            android:textColorHint="@color/nexus_text_secondary"
                            android:textSize="14sp"
                            android:selectAllOnFocus="true"
                            android:singleLine="true" />

                        <ImageView
                            android:id="@+id/btn_clear_et"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/tab_close"
                            android:visibility="gone"
                            app:tint="@color/nexus_text_secondary" />

                        <TextView
                            android:id="@+id/pinch_indicator"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:background="@drawable/pinch_indicator_bg"
                            android:paddingLeft="6dp"
                            android:paddingRight="6dp"
                            android:text="PINCH"
                            android:textColor="@color/nexus_bg"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btn_reload_top"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="12dp"
                        android:src="@drawable/reload"
                        app:tint="@color/nexus_text_secondary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- WebView Container -->
            <FrameLayout
                android:id="@+id/webviews"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/address_bar_container"
                android:layout_above="@id/toolbar_container"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressbar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_below="@id/address_bar_container"
                android:progressTint="@color/nexus_accent"
                android:visibility="gone" />

            <!-- Search in page pane -->
            <LinearLayout
                android:id="@+id/searchPane"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_above="@id/toolbar_container"
                android:background="@color/nexus_sidebar"
                android:padding="4dp"
                android:visibility="gone"
                android:gravity="center_vertical">
                <EditText
                    android:id="@+id/searchEdit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Find in page"
                    android:singleLine="true"
                    android:textColor="@color/nexus_text_primary"
                    android:textColorHint="@color/nexus_text_secondary" />
                <TextView
                    android:id="@+id/searchCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="4dp"
                    android:textColor="@color/nexus_text_secondary" />
                <ImageView
                    android:id="@+id/searchFindNext"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/forward"
                    app:tint="@color/nexus_text_secondary" />
                <ImageView
                    android:id="@+id/searchFindPrev"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/back"
                    app:tint="@color/nexus_text_secondary" />
                <ImageView
                    android:id="@+id/searchClose"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/tab_close"
                    app:tint="@color/nexus_text_secondary" />
            </LinearLayout>

            <!-- Bottom Toolbar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/toolbar_container"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_alignParentBottom="true"
                app:cardBackgroundColor="@color/nexus_sidebar"
                app:cardElevation="8dp"
                app:cardCornerRadius="0dp">

                <LinearLayout
                    android:id="@+id/toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </RelativeLayout>

        <landau.sweb.PinchOverlayView
            android:id="@+id/pinch_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />

    </landau.sweb.PinchWebViewContainer>

    <!-- Nexus Sidebar -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/nexus_sidebar">
        <include layout="@layout/layout_sidebar" />
    </com.google.android.material.navigation.NavigationView>

    <FrameLayout
        android:id="@+id/fullScreenVideo"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone" />

</androidx.drawerlayout.widget.DrawerLayout>
